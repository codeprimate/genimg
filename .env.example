# OpenRouter API Key (required, unless provided via --api-key CLI option)
# Get from: https://openrouter.ai/keys
# Used for: Image generation
# Note: Can also be provided via CLI with: genimg generate --api-key sk-or-v1-...
OPENROUTER_API_KEY=sk-or-v1-...

# Default image generation model (optional override)
# Unset values inherit from src/genimg/models.yaml (default_image_model).
# Format: provider/model-name
# GENIMG_DEFAULT_MODEL=bytedance-seed/seedream-4.5

# Default Ollama image model when provider is ollama (optional override)
# Unset values inherit from models.yaml (default_ollama_image_model).
# GENIMG_DEFAULT_OLLAMA_IMAGE_MODEL=x/z-image-turbo

# Default optimization model (optional override)
# Unset values inherit from models.yaml (default_optimization_model).
# Must be installed in Ollama (ollama pull …). Prompt optimization uses the Ollama HTTP API.
# GENIMG_OPTIMIZATION_MODEL=huihui_ai/qwen3.5-abliterated:4b

# Ollama HTTP base URL (optional). Used for prompt optimization and Ollama image generation.
# Default if unset: http://127.0.0.1:11434
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# Run integration tests (optional; set to 1 to allow pytest -m integration)
# Integration tests call the real OpenRouter API: slow and costs money.
# GENIMG_RUN_INTEGRATION_TESTS=1
